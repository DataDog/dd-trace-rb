# The rbs core bundled with our Steep does not declare `ObjectSpace::WeakMap`,
# which `Datadog::OpenFeature::Hooks::SpanEnrichmentHook::SpanEnrichmentStateStore`
# uses as its weak, per-trace state store. This minimal shim lets `WeakMap.new`
# resolve; the store itself types the map as `untyped`, so only the constant
# needs to exist.
#
# Lives under `vendor/rbs/ruby/` (auto-loaded by the Steepfile's `vendor/rbs`
# repo loop, same mechanism as `vendor/rbs/jruby`) because it augments a core
# Ruby type rather than mirroring a `lib/` file.
module ObjectSpace
  class WeakMap
    def initialize: () -> void

    def []: (untyped key) -> untyped

    def []=: (untyped key, untyped value) -> untyped
  end
end
