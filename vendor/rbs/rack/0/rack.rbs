module Rack
  type env = Hash[String, untyped] # should be `any`
  type headers = Hash[String, String | Array[String]]
  type query = Hash[String, String? | Array[String?]]
  type response = [Integer, headers, Response::_Body]
  type app = ^(env) -> response

  def self.release: () -> String

  module Utils
    def self.parse_query: (String? query_string, ?String? separator) ?{ (String) -> String } -> query
  end

  class Request
    def initialize: (Rack::env env) -> void

    def env: () -> Rack::env

    def query_string: () -> String

    def request_method: () -> String

    def content_type: () -> String?

    def content_length: () -> String?

    def url: () -> String

    def fullpath: () -> String

    def cookies: () -> Hash[String, String]

    def host: () -> String

    def user_agent: () -> String

    def params: () -> Hash[String, untyped] # should be `any`

    def POST: () -> Hash[String, untyped]

    def form_data?: () -> bool

    def parseable_data?: () -> bool

    def body: () -> untyped

    def get?: () -> bool

    def post?: () -> bool

    def path: () -> String
  end

  class Response
    interface _Body
      def each: () { (String) -> void } -> void

      def respond_to?: (Symbol method, ?boolish include_all) -> bool

      def to_ary: () -> Array[String]?
    end

    def initialize: (?untyped body, ?untyped status, ?headers headers) -> void
  end
end
