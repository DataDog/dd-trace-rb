module Rack
  type env = ::Hash[::String, untyped] # should be `any`
  type response = [::Integer, ::Hash[::String, ::String], Response::_Body]
  type app = ^(env) -> response

  class Request
    def initialize: (Rack::env env) -> void

    def env: () -> Rack::env

    def params: () -> ::Hash[::String, untyped] # should be `any`

    def body: () -> untyped

    def get?: () -> bool

    def post?: () -> bool

    def path: () -> ::String
  end

  class Response
    interface _Body
      def each: () { (::String) -> void } -> void

      def respond_to?: (::Symbol method, ?boolish include_all) -> bool

      def to_ary: () -> ::Array[::String]?
    end

    def initialize: (?untyped body, ?untyped status, ?untyped headers) -> void
  end
end
