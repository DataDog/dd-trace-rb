module Datadog
  module Core
    module TagBuilder
      type tags = ::Hash[::String, ::String]

      self.@fixed_environment_tags: tags_hash

      def self.fixed_environment_tags: () -> tags_hash

      def self.tags: (Datadog::Core::Configuration::Settings settings) -> tags_hash

      def self.serialize_tags: (tags_hash tags) -> ::String
    end
  end
end
