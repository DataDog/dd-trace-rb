module Datadog
  module Core
    class HeaderCollection
      def get: (::String header_name) -> ::String?
      def self.from_hash: (::Hash[::String, untyped] hash) -> HashHeaderCollection
    end

    class HashHeaderCollection < HeaderCollection
      @hash: ::Hash[::String, untyped]

      def initialize: (::Hash[::String, untyped] hash) -> void

      def get: (::String header_name) -> ::String?
    end
  end
end
