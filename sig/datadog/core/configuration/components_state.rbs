module Datadog
  module Core
    module Configuration
      class ComponentsState
        @telemetry_enabled: bool

        @remote_started: bool

        @di_implicitly_enabled: bool

        def initialize: (telemetry_enabled: bool, remote_started: bool?, ?di_implicitly_enabled: bool) -> void

        def telemetry_enabled?: () -> bool

        def remote_started?: () -> bool

        def di_implicitly_enabled?: () -> bool
      end
    end
  end
end
