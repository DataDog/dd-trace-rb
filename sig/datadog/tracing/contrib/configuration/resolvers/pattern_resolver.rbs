module Datadog
  module Tracing
    module Contrib
      module Configuration
        module Resolvers
          class PatternResolver < Contrib::Configuration::Resolver[untyped, untyped, untyped]
            def resolve: (untyped value) -> untyped

            def parse_matcher: (untyped matcher) -> untyped
          end
        end
      end
    end
  end
end
