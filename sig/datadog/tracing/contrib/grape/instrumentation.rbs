module Datadog
  module Tracing
    module Contrib
      module Grape
        module Instrumentation
          module GenerateApiMethodPatch
            def generate_api_method: (*untyped params) ?{ () -> untyped } -> untyped
          end

          module ExecutePatch
            def execute: (*untyped args) -> untyped
          end

          module InstanceMethods
            def run: (*untyped args) -> untyped
          end
        end
      end
    end
  end
end
