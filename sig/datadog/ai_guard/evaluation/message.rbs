module Datadog
  module AIGuard
    module Evaluation
      class Message
        type content_part = ContentPart::Text | ContentPart::ImageURL

        attr_reader role: ::Symbol
        attr_reader content: ::String | ::Array[content_part] | nil
        attr_reader tool_call: ToolCall?
        attr_reader tool_call_id: ::String?

        def initialize: (
          role: ::String | ::Symbol,
          ?content: ::String | ::Array[content_part] | nil,
          ?tool_call: ToolCall?,
          ?tool_call_id: ::String?
        ) -> void
      end
    end
  end
end
