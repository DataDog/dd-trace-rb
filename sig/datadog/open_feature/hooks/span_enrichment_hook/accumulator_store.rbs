module Datadog
  module OpenFeature
    module Hooks
      class SpanEnrichmentHook
        # Keyed WEAKLY by the active trace operation via object identity. Typed as
        # `untyped` because `Datadog::Tracing.active_trace` is declared to return
        # a `TraceSegment` while at runtime the open trace is a `TraceOperation`;
        # the store only uses the value as an identity key.
        class AccumulatorStore
          # Typed `untyped`: the WeakMap is keyed by trace operations used only as
          # identity, and the public methods below carry the precise contract.
          @states: untyped

          def initialize: () -> void

          def []: (untyped trace_op) -> Accumulator?

          def []=: (untyped trace_op, Accumulator accumulator) -> Accumulator

          def delete: (untyped trace_op) -> void

          def clear!: () -> void
        end
      end
    end
  end
end
