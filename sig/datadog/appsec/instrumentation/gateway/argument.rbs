module Datadog
  module AppSec
    module Instrumentation
      class Gateway
        class Argument
          def initialize: (*untyped) -> void
        end

        class DataContainer < Argument
          @data: untyped

          @context: Context

          attr_reader data: untyped

          attr_reader context: Context

          def initialize: (untyped data, context: Context) -> void
        end
      end
    end
  end
end
