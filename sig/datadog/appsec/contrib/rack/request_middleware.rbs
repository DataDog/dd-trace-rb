module Datadog
  module AppSec
    module Contrib
      module Rack
        RESPONSE_HEADERS_TAGS: ::Array[::String]

        WAF_VENDOR_HEADERS_TAGS: ::Array[::String]

        class RequestMiddleware
          @app: ::Rack::app

          def initialize: (::Rack::app app, ?::Hash[::Symbol, untyped] opt) -> void

          attr_reader logger: untyped

          def call: (::Rack::env env) -> ::Rack::response
        end
      end
    end
  end
end
