module Datadog
  module AppSec
    module Contrib
      module Rack
        class RequestBodyMiddleware
          @app: ::Rack::app

          def initialize: (::Rack::app app, ?::Hash[::Symbol, untyped] opt) -> void

          # Returns Rack::response in practice, but Steep cannot prove it
          # through the catch/block control flow (http_response may appear nil).
          def call: (::Rack::env env) -> ::Rack::response?
        end
      end
    end
  end
end
