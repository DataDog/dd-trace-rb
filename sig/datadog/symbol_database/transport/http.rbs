module Datadog
  module SymbolDatabase
    module Transport
      module HTTP
        SYMDB_ENDPOINT: API::Endpoint

        def self.build: (
          agent_settings: Core::Configuration::AgentSettingsResolver::AgentSettings,
          ?logger: Core::Logger,
          ?headers: Hash[String, String]?
